*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; cursor: none !important; }

  :root {
  --void:         #0a0a1a;
  --void-mid:     #0f0f24;
  --void-soft:    #14142e;
  --gold:         #c9a96e;
  --gold-bright:  #dfc08a;
  --gold-dim:     #8a6e42;
  --cream:        #f5f0e8;
  --cream-dim:    rgba(245, 240, 232, 0.55);
  --font-display: 'IM Fell English', Georgia, serif;
  --font-serif:   'Cormorant Garamond', Georgia, serif;
  --font-sans:    'Optima', 'Candara', Tahoma, sans-serif;
  --ease-silk:    cubic-bezier(0.77, 0, 0.175, 1);
  --ease-gentle:  cubic-bezier(0.25, 0.46, 0.45, 0.94);
  --dur-fast:     0.3s;
  --dur-mid:      0.6s;
  --dur-slow:     1.1s;
  --gap-lg:       3.2rem;
  --gap-xl:       6rem;
  --gap-2xl:      10rem;
  --tracking-nav:   0.56em;
  --tracking-label: 0.32em;
  --tracking-body:  0.04em;
  }

  html { font-size: 16px; scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

  body {
  font-family: var(--font-serif);
  background-color: var(--void);
  color: var(--cream);
  overflow-x: hidden;
  cursor: none;
  line-height: 1;
  }

  /*--SIGN DISPLAY--*/
/* fundo escuro — ocupa a tela toda */
#sign-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1000;
}

#sign-modal.open {
  display: flex;
}

/* caixa do conteúdo — centralizada dentro do fundo */
#modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400px;
  height: 500px;
  background: var(--void-mid);
  border: 1px solid rgba(201,169,110,0.2);
  padding: 2.4rem 2.8rem;
  z-index: 1001;
}
#modal-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
}

  /* ── CURSOR ── */
  #cursor {
  position: fixed;
  top: 0; left: 0;
  z-index: 9999;
  width: 6px; height: 6px;
  background: var(--gold);
  border-radius: 50%;
  pointer-events: none;
  transform: translate(-50%, -50%);
  mix-blend-mode: screen;
  }

  /* Anel — tamanho reduzido, sem transition de posição */
  #cursor-ring {
  position: fixed;
  top: 0; left: 0;
  z-index: 9997;
  width: 28px; height: 28px;
  border: 1px solid rgba(201, 169, 110, 0.6);
  border-top-color: var(--gold);
  border-radius: 50%;
  pointer-events: none;
  transform: translate(-50%, -50%) rotate(0deg);
  animation: cursorSpin 4s linear infinite;
  }

  @keyframes cursorSpin {
  to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  /* ── NAV ── */
  nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 500;
  padding: 2.2rem 5vw;
  display: flex;
  align-items: center;
  justify-content: space-between;
  opacity: 0;
  animation: fadeIn 1s 0.4s var(--ease-gentle) forwards;
  }

  nav::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, rgba(10,10,26,0.92) 0%, rgba(10,10,26,0) 100%);
  pointer-events: none;
  }

  .nav-logo {
  font-family: var(--font-display);
  font-size: 1.05rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--cream);
  text-decoration: none;
  transition: color var(--dur-fast);
  }
  .nav-logo::after {
  content: '✦';
  display: inline-block;
  margin-left: 0.6em;
  font-size: 0.5em;
  color: var(--gold);
  vertical-align: middle;
  animation: starPulse 3s ease-in-out infinite;
  }
  .nav-logo:hover { color: var(--gold); }

  .nav-links { display: flex; gap: 2.8rem; list-style: none; }
  .nav-links a {
  font-family: var(--font-sans);
  font-size: 0.58rem;
  letter-spacing: var(--tracking-nav);
  text-transform: uppercase;
  color: rgba(245,240,232,0.45);
  text-decoration: none;
  position: relative;
  transition: color var(--dur-fast);
  cursor: none;
  }
  .nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 1px;
  background: var(--gold);
  transition: width var(--dur-mid) var(--ease-silk);
  }
  .nav-links a:hover { color: var(--gold); }
  .nav-links a:hover::after { width: 100%; }

  /* ── HERO ── */
  .hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 0 5vw;
  }

  #stars {
  position: absolute;
  inset: 0;
  pointer-events: none;
  }

  .hero-content {
  position: relative;
  z-index: 10;
  width: min(40vw, 620px);
  text-align: left;
  margin-left: 5vw;
  margin-right: auto;
  opacity: 0;
  animation: heroReveal 1.2s 1.6s var(--ease-gentle) forwards;
  }

  @keyframes heroReveal {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
  }

  .hero-eyebrow {
  font-family: var(--font-sans);
  font-size: 0.58rem;
  letter-spacing: var(--tracking-label);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.8rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 32px; height: 1px; background: var(--gold-dim); }

  .hero-title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 5.5vw, 5.2rem);
  font-weight: 400;
  line-height: 1.08;
  color: var(--cream);
  margin-bottom: 1.4rem;
  }
  .hero-title em { font-style: italic; color: var(--gold); display: block; }

  .hero-sub {
  font-family: var(--font-serif);
  font-style: italic;
  font-size: clamp(0.95rem, 1.3vw, 1.2rem);
  font-weight: 300;
  line-height: 1.75;
  color: var(--cream-dim);
  margin-bottom: 2.8rem;
  max-width: 380px;
  letter-spacing: var(--tracking-body);
  }

  .hero-cta { display: flex; align-items: center; gap: 1.6rem; flex-wrap: wrap; }

  /* ── BOTÕES ── */
  .btn-primary, .btn-secondary {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-sans);
  font-size: 0.58rem;
  letter-spacing: var(--tracking-nav);
  text-transform: uppercase;
  text-decoration: none;
  cursor: none;
  position: relative;
  overflow: hidden;
  transition: color var(--dur-fast);
  border: none;
  outline: none;
  background: none;
  padding: 0.9rem 2.4rem;
  }

  .btn-primary {
  color: var(--void);
  background: var(--gold);
  border: 1px solid var(--gold);
  }
  .btn-primary::after {
  content: '';
  position: absolute; inset: 0;
  background: var(--cream);
  transform: scaleX(0);
  transform-origin: right;
  transition: transform var(--dur-mid) var(--ease-silk);
  }
  .btn-primary:hover { color: var(--void); }
  .btn-primary:hover::after { transform: scaleX(1); transform-origin: left; }

  .btn-secondary {
  color: var(--cream-dim);
  border: 1px solid rgba(245,240,232,0.2);
  }
  .btn-secondary::after {
  content: '';
  position: absolute; inset: 0;
  background: rgba(201,169,110,0.08);
  transform: scaleX(0);
  transform-origin: right;
  transition: transform var(--dur-mid) var(--ease-silk);
  }
  .btn-secondary:hover { color: var(--gold); border-color: rgba(201,169,110,0.4); }
  .btn-secondary:hover::after { transform: scaleX(1); transform-origin: left; }

  .btn-primary span, .btn-secondary span { position: relative; z-index: 1; }

  /* ── SECTION HEADER ── */
  .section-header { text-align: center; margin-bottom: var(--gap-lg);}

  .section-label {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  font-family: var(--font-sans);
  font-size: 0.9rem;
  letter-spacing: var(--tracking-label);
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.2rem;
  }
  .section-label::before, .section-label::after { content: '—'; opacity: 0.4; }

  .section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 3.5vw, 3.4rem);
  font-weight: 400;
  line-height: 1.12;
  color: var(--cream);
  }

  /* ── SIGNS ── */
  .signs-section {
  padding: var(--gap-2xl) 5vw var(--gap-xl);
  max-width: 1300px;
  margin: 0 auto;
  }

  .signs-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(201,169,110,0.1);
  border: 1px solid rgba(201,169,110,0.1);
  margin: 0 auto;
  }

  .sign-card {
  position: relative;
  background: var(--void);
  padding: 2.2rem 1.6rem 2rem;
  text-align: center;
  cursor: none;
  overflow: hidden;
  transition: background var(--dur-fast);
  opacity: 0;
  transform: translateY(20px);
  transition: background var(--dur-fast), opacity var(--dur-slow) var(--ease-gentle), transform var(--dur-slow) var(--ease-gentle);
  }
  .sign-card.visible { opacity: 1; transform: translateY(0); }

.sign-card::before {
content: '';
position: absolute; inset: 0;
background: radial-gradient(ellipse 60% 60% at 50% 30%, rgba(201,169,110,0.1) 0%, transparent 70%);
opacity: 0;
transition: opacity var(--dur-mid) var(--ease-gentle);
pointer-events: none;
}
.sign-card::after {             
content: '';
position: absolute;
bottom: 0; left: 0;
width: 0; height: 1px;
background: linear-gradient(90deg, transparent, var(--gold), transparent);
transition: width var(--dur-mid) var(--ease-silk);
}
.sign-card:hover { background: var(--void-soft); }
.sign-card:hover::before { opacity: 1; }
.sign-card:hover::after { width: 100%; }
.sign-card:hover .sign-glyph { color: var(--gold-bright); transform: scale(1.12) translateY(-2px); }
.sign-card:hover .sign-name { color: var(--gold); }

.sign-glyph {
display: block;
font-size: 1.6rem;
color: var(--gold-dim);
margin-bottom: 0.8rem;
transition: color var(--dur-fast), transform var(--dur-mid) var(--ease-gentle);
line-height: 1;
}
.sign-name {
font-family: var(--font-display);
font-size: 0.95rem;
letter-spacing: 0.1em;
color: var(--cream);
display: block;
margin-bottom: 0.35rem;
transition: color var(--dur-fast);
text-transform: uppercase;
}
.sign-date {
font-family: var(--font-sans);
font-size: 0.5rem;
letter-spacing: 0.15em;
color: rgba(245,240,232,0.3);
text-transform: uppercase;
}

/* ── READING ── */
.reading-section {
background: var(--void-mid);
padding: var(--gap-xl) 5vw;
border-top: 1px solid rgba(201,169,110,0.08);
border-bottom: 1px solid rgba(201,169,110,0.08);
}
.reading-inner {
max-width: 1100px;
margin: 0 auto;
display: grid;
grid-template-columns: 1fr 1fr;
gap: var(--gap-xl);
align-items: center;
}
.reading-text { max-width: 420px; }

.reading-label {
display: inline-flex;
align-items: center;
gap: 0.8rem;
font-family: var(--font-sans);
font-size: 0.56rem;
letter-spacing: var(--tracking-label);
text-transform: uppercase;
color: var(--gold);
margin-bottom: 1.2rem;
}

.reading-title {
font-family: var(--font-display);
font-size: clamp(2rem, 3vw, 2.8rem);
font-weight: 400;
line-height: 1.15;
color: var(--cream);
margin-top: 1rem;
margin-bottom: 1.4rem;
}
.reading-body {
font-family: var(--font-serif);
font-style: italic;
font-size: 1.0rem;
font-weight: 300;
line-height: 1.9;
color: var(--cream-dim);
margin-bottom: 2rem;
letter-spacing: var(--tracking-body);
}

/* Círculo astral */
.astro-circle {
position: relative;
width: min(320px, 38vw);
height: min(320px, 38vw);
margin: 0 auto;
}
.ac-outer {
position: absolute; inset: 0;
border: 1px solid rgba(201,169,110,0.2);
border-radius: 50%;
animation: ringRotate 40s linear infinite;
}
.ac-inner {
position: absolute;
inset: 20%;
border: 1px solid rgba(201,169,110,0.12);
border-radius: 50%;
animation: ringRotate 25s linear infinite reverse;
}
.ac-dot {
position: absolute;
width: 5px; height: 5px;
background: var(--gold);
border-radius: 50%;
box-shadow: 0 0 8px var(--gold);
}
.ac-core {
position: absolute;
inset: 0;
display: flex;
align-items: center;
justify-content: center;
font-size: 2rem;
color: var(--gold);
animation: starPulse 4s ease-in-out infinite;
}
@keyframes ringRotate { to { transform: rotate(360deg); } }
@keyframes starPulse { 0%,100% { opacity: 0.5; } 50% { opacity: 1; } }

/* ── PILLARS ── */
.pillars {
padding: var(--gap-xl) 5vw;
max-width: 1100px;
margin: 0 auto;
}
.pillars-inner {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 0;
border: 1px solid rgba(201,169,110,0.1);
}
.pillar {
padding: 3rem 2.4rem;
border-right: 1px solid rgba(201,169,110,0.1);
position: relative;
overflow: hidden;
cursor: none;
transition: background var(--dur-fast);
}
.pillar:last-child { border-right: none; }
.pillar::before {
content: '';
position: absolute; inset: 0;
background: radial-gradient(ellipse 80% 50% at 50% 100%, rgba(201,169,110,0.06) 0%, transparent 70%);
opacity: 0;
transition: opacity var(--dur-mid);
}
.pillar:hover { background: var(--void-soft); }
.pillar:hover::before { opacity: 1; }

.pillar-num {
font-family: var(--font-display);
font-size: 4rem;
color: rgba(201,169,110,0.12);
line-height: 1;
margin-bottom: 1rem;
}
.pillar-title {
font-family: var(--font-display);
font-size: 1.25rem;
color: var(--cream);
margin-bottom: 0.9rem;
letter-spacing: 0.02em;
}
.pillar-body {
font-family: var(--font-serif);
font-size: 0.88rem;
font-weight: 300;
line-height: 1.85;
color: rgba(245,240,232,0.45);
letter-spacing: var(--tracking-body);
}

/* ── SELECTOR / FORM ── */
.selector-section {
padding: var(--gap-xl) 5vw var(--gap-2xl);
max-width: 640px;
margin: 0 auto;
text-align: center;
}
.birth-form {
display: flex;
flex-direction: column;
gap: 1.4rem;
margin-top: var(--gap-lg);
}
.form-row {
display: grid;
grid-template-columns: repeat(2, 1fr);
gap: 1.2rem;
}
.form-field { display: flex; flex-direction: column; gap: 0.5rem; text-align: left; }
.form-field label {
font-family: var(--font-sans);
font-size: 0.5rem;
letter-spacing: var(--tracking-label);
text-transform: uppercase;
color: var(--gold-dim);
}
.form-field input,
.form-field select {
background: transparent;
border: none;
border-bottom: 1px solid rgba(201,169,110,0.2);
padding: 0.65rem 0;
font-family: var(--font-serif);
font-style: italic;
font-size: 1.0rem;
font-weight: 300;
color: var(--cream);
outline: none;
cursor: none;
border-radius: 0;
transition: border-color var(--dur-fast), color var(--dur-fast);
-webkit-appearance: none;
appearance: none;
}
.form-field input::placeholder { color: rgba(245,240,232,0.2); }
.form-field input:focus, .form-field select:focus { border-color: var(--gold); color: var(--gold); }
.form-field select option { background: var(--void-mid); color: var(--cream); }

input[type=number]::-webkit-outer-spin-button,
input[type=number]::-webkit-inner-spin-button {
-webkit-appearance: none;
}

input[type=number] {
appearance: textfield;
}

.reveal-btn {
align-self: center;
margin-top: 0.6rem;
padding: 1.1rem 3.6rem;
font-family: var(--font-sans);
font-size: 0.58rem;
letter-spacing: var(--tracking-nav);
text-transform: uppercase;
color: var(--cream);
background: transparent;
border: 1px solid rgba(245,240,232,0.25);
border-radius: 0;
cursor: none;
position: relative;
overflow: hidden;
transition: color var(--dur-fast);
}
.reveal-btn::before {
content: '';
position: absolute; inset: 0;
background: var(--gold);
transform: scaleY(0);
transform-origin: bottom;
transition: transform var(--dur-mid) var(--ease-silk);
z-index: 0;
}
.reveal-btn:hover { color: var(--void); }
.reveal-btn:hover::before { transform: scaleY(1); }
.reveal-btn span { position: relative; z-index: 1; }

/* ── RESULT PANEL ── */
.result-panel {
margin-top: 2rem;
padding: 2.4rem 2.8rem;
border: 1px solid rgba(201,169,110,0.2);
background: linear-gradient(135deg, rgba(201,169,110,0.04) 0%, transparent 60%);
text-align: left;
display: none;
}
.result-panel.show { display: block; animation: fadeUp 0.6s var(--ease-gentle) forwards; }

.result-sign {
font-family: var(--font-display);
font-size: 2.2rem;
color: var(--gold);
letter-spacing: 0.05em;
margin-bottom: 0.6rem;
}
.result-desc {
font-family: var(--font-serif);
font-style: italic;
font-size: 0.92rem;
font-weight: 300;
line-height: 1.85;
color: var(--cream-dim);
}

/* ── DIVIDER ── */
.divider {
width: 80%;
height: 1px;
background: linear-gradient(to right, transparent, rgba(201,169,110,0.2) 20%, rgba(201,169,110,0.2) 80%, transparent);
}

/* ── FOOTER ── */
footer {
padding: 3rem 5vw;
display: flex;
align-items: center;
justify-content: space-between;
border-top: 1px solid rgba(201,169,110,0.1);
}
.footer-logo {
font-family: var(--font-display);
font-size: 0.9rem;
letter-spacing: 0.18em;
text-transform: uppercase;
color: rgba(245,240,232,0.35);
}
.footer-note {
font-family: var(--font-sans);
font-size: 0.5rem;
letter-spacing: 0.12em;
color: rgba(245,240,232,0.15);
text-transform: uppercase;
}

/* ── REVEAL ANIMATIONS ── */
.reveal {
opacity: 0;
transform: translateY(28px);
transition: opacity var(--dur-slow) var(--ease-gentle), transform var(--dur-slow) var(--ease-gentle);
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── KEYFRAMES ── */
@keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--void); }
::-webkit-scrollbar-thumb { background: rgba(201,169,110,0.3); border-radius: 0; }
::-webkit-scrollbar-thumb:hover { background: rgba(201,169,110,0.6); }
::selection { background: rgba(201,169,110,0.25); color: var(--gold-bright); }

/* ── RESPONSIVO ── */
@media (max-width: 1024px) {
.signs-grid { grid-template-columns: repeat(3, 1fr); }
.hero-content { width: min(70vw, 560px); margin-left: 0; }
.reading-inner { grid-template-columns: 1fr; gap: var(--gap-lg); }
}
@media (max-width: 768px) {
nav { padding: 1.4rem 5vw; }
.nav-links { display: none; }
.hero-content { width: 90vw; text-align: center; margin: 0 auto; }
.hero-eyebrow { justify-content: center; }
.hero-sub { max-width: 100%; }
.hero-cta { justify-content: center; }
.signs-grid { grid-template-columns: repeat(2, 1fr); }
.pillars-inner { grid-template-columns: 1fr; }
.pillar { border-right: none; border-bottom: 1px solid rgba(201,169,110,0.1); }
.pillar:last-child { border-bottom: none; }
.form-row { grid-template-columns: 1fr; }
footer { flex-direction: column; gap: 1rem; text-align: center; }
#cursor, #cursor-ring { display: none; }
body { cursor: auto; }
.btn-primary, .btn-secondary, .sign-card, .reveal-btn, .nav-links a { cursor: pointer; }
}
@media (max-width: 480px) {
.signs-grid { grid-template-columns: repeat(2, 1fr); }
.hero-title { font-size: 2.6rem; }
.reading-title { font-size: 1.8rem; }
}